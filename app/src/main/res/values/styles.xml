<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppText.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppText.Heading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppText.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppText.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppButton.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/color_option_button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="elevation">0dp</item>
    </style>

</resources>
