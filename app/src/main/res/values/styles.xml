<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/figma_hand</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AppText.LargeTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">48sp</item>
        <item name="android:fontFamily">@font/figma_hand</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="AppText.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppText.Body">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppText.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="AppButton.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/select_option_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="AppButton.Login" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@android:color/white</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/figma_hand</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="TextDropdownItem">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>

    <style name="MenuFieldStyle" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/personal_card_background</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="MenuFieldText">
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:fontFamily">@font/figma_hand</item>
    </style>
</resources>
