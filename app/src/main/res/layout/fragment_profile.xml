<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background_personal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/avatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/sym_def_app_icon"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvName"
            style="@style/AppText.Heading"
            android:text="Phạm Đức Long"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_container_rounded"
            android:padding="16dp">

            <TextView style="@style/AppText.Body" android:text="Địa chỉ:   Đại học FPT HN"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_soft" android:layout_marginVertical="8dp"/>
            <TextView style="@style/AppText.Body" android:text="Số điện thoại:  0385189339"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_soft" android:layout_marginVertical="8dp"/>
            <TextView style="@style/AppText.Body" android:text="Trình độ JLPT N1"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnVip"
            style="@style/AppButton.Primary"
            android:text="Nâng cấp VIP"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"/>
    </LinearLayout>
</ScrollView>
